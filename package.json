{
  "name": "planner",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "predev": "docker-compose up -d",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "biome format --write .",
    "check-types": "turbo run check-types",
    "db:migrate": "pnpm --filter @repo/api db:migrate",
    "db:push": "pnpm --filter @repo/api db:push"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "turbo": "^2.9.16",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1d1485",
  "engines": {
    "node": ">=18"
  }
}
