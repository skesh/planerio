generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  todos    Todo[]
  projects Project[]
  runners  Runner[]
}

model Project {
  id          String   @id @default(cuid())
  externalId  String?
  description String?  @default("")
  name        String
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  todos  Todo[]
  runners Runner[]
}

model Runner {
  id           String    @id @default(cuid())
  name         String
  type         String
  enabled      Boolean   @default(true)
  schedule     String?
  config       Json      @default("{}")
  lastRunAt    DateTime?
  lastStatus   String?
  errorMessage String?
  userId       String
  projectId    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

model Todo {
  id             String   @id @default(cuid())
  externalId     String?
  externalSource String?
  title       String
  description String   @default("")
  tags        String[]
  priority    Boolean  @default(false)
  date        String   @default("")
  time        String   @default("")
  endDate     String   @default("")
  repeat      String?
  dependsOn   String[]
  done        Boolean  @default(false)
  doneDate    String   @default("")
  userId      String
  projectId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}
